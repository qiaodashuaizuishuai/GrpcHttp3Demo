{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MediaServer": {
    "UdpForwarding": {
      "Enabled": false,
      "QueueCapacityPerTarget": 2048,
      "MaxPpsPerTarget": 2000,
      "MaxBpsPerTarget": 50000000,
      "RetryOnNoBuffer": true,
      "MaxRetries": 1,
      "RetryDelayMs": 1
    }
  },
  "DevSettings": {
    "BroadcastToAll": true
  }
}
